{
  "name": "agentq",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "agentq": "./src/cli.ts"
  },
  "scripts": {
    "postinstall": "lefthook install",
    "agentq": "bun run src/cli.ts",
    "lint": "bunx biome check --formatter-enabled=false .",
    "lint:fix": "bunx biome check --write --formatter-enabled=false .",
    "fmt:fix": "bunx biome check --write --linter-enabled=false .",
    "fmt:check": "bunx biome check --linter-enabled=false .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test --pass-with-no-tests",
    "check:fast": "bun run fmt:check && bun run lint && bun run typecheck",
    "check": "bun run check:fast && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.9",
    "typescript": "6.0.3"
  }
}
